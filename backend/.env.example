# ============================================================
# KEPLER AI Backend — Environment Variables
# ============================================================
# Copy this file to .env for local development.
# In production (Railway), set these directly in the dashboard
# under Settings → Variables.
# NEVER commit a filled-in .env file to version control.
# ============================================================


# ── App ──────────────────────────────────────────────────────
PROJECT_NAME=KEPLER AI
API_V1_STR=/api/v1

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_hex_string

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=https://keplerai.vercel.app,http://localhost:5173

# ── MongoDB ──────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/orbital_guardian?retryWrites=true&w=majority

# ── Space-Track.org (optional — falls back to Celestrak) ─────
# Register at https://www.space-track.org/auth/login
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# ── Celestrak fallback ────────────────────────────────────────
SATELLITE_PROVIDER_PRIORITY=space-track,celestrak,cache
CELESTRAK_BASE_URL=https://celestrak.org

# ── OpenAI (optional — required for AI agent workflows) ───────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── NASA DONKI Space Weather API ─────────────────────────────
# Get a free key at https://api.nasa.gov/#signUp
# DEMO_KEY works but is rate-limited (30 req/hour).
NASA_DONKI_API_KEY=DEMO_KEY

# ── Celery / Redis / RabbitMQ ────────────────────────────────
# Only needed if running separate Celery workers.
# The built-in asyncio scheduler does NOT require these.
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
